# Cloudflare Pages custom response headers.
# https://developers.cloudflare.com/pages/configuration/headers/
#
# Strategy:
#   · Hashed bundles under /assets/ are content-addressable → cache forever.
#   · Root index.html must revalidate every load so new deploys land instantly.
#   · Static images get a long cache with "must-revalidate" so hot fixes still
#     reach users when we re-upload.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=604800, must-revalidate

/*.mp4
  Cache-Control: public, max-age=604800, must-revalidate

/*.webm
  Cache-Control: public, max-age=604800, must-revalidate

/*.svg
  Cache-Control: public, max-age=604800, must-revalidate

/favicon.svg
  Cache-Control: public, max-age=86400

# Discovery files for AI agents and search engines · short cache so we can
# iterate. Explicit content-types for safety.
/llms.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate
